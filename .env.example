# ─── LLM ──────────────────────────────────────────────────
# Which LLM provider to use: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Anthropic (Claude Haiku 3.5 — primary)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o-mini — fallback)
OPENAI_API_KEY=

# Gemini Flash — optional benchmark
GOOGLE_AI_API_KEY=

# ─── skarya.ai ────────────────────────────────────────────
# Base URL for skarya.ai API calls (server-side only)
SKARYA_BASE_URL=https://skarya.skarya.ai

# For prototype: hardcode a test user (replace with real auth later)
PROTOTYPE_USER_EMAIL=pranav.patil@nikqik.com
PROTOTYPE_USER_NAME=Pranav Patil
PROTOTYPE_WORKSPACE_ID=692ba14ce2552a8b5afe6e9a
PROTOTYPE_BOARD_ID=694a87f7e6aa80a347e86e5a

# Session cookie from skarya.ai (copy from browser DevTools for prototype)
# In production this will come from the user's request automatically
SKARYA_SESSION_COOKIE=

# ─── Database ─────────────────────────────────────────────
# SQLite for prototype — just a file path
DATABASE_URL=file:./standup.db

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
